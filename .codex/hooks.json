{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; if echo \"$FILE\" | grep -qE '(package-lock\\.json|\\.env(\\..+)?$)'; then echo \"BLOCKED: Do not edit $FILE. package-lock.json is Railway-critical; .env files must never be modified by Claude.\"; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/blair/Desktop/Development/Splitlease && FILE=\"$CLAUDE_FILE_PATH\"; if echo \"$FILE\" | grep -q '/DataZone/'; then cd DataZone && npx tsc --noEmit 2>&1 | head -5; elif echo \"$FILE\" | grep -q '/Backend/'; then cd Backend && npx tsc --noEmit 2>&1 | head -5; fi",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/blair/Desktop/Development/Romem/.codex/hooks/project-memory-hook.cjs",
            "timeout": 5,
            "statusMessage": "Loading project memory..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/blair/Desktop/Development/Romem/.codex/hooks/project-memory-hook.cjs",
            "timeout": 5,
            "statusMessage": "Submitting project memory..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/blair/Desktop/Development/Romem/.codex/hooks/project-memory-hook.cjs",
            "timeout": 5,
            "statusMessage": "Checking project memory..."
          }
        ]
      }
    ]
  }
}

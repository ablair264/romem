{
  "name": "romem",
  "version": "1.0.0",
  "description": "Mastra-backed project memory orchestration workspace",
  "main": "dist/server/server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "next dev -p 3000",
    "build": "npm run build:client && npm run build:server",
    "build:client": "next build && node scripts/copy-client.js",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "test": "vitest run",
    "smoke-test": "node scripts/smoke-test.js",
    "legacy:mcp": "node index.js",
    "legacy:gui": "node gui.js"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@mastra/core": "^1.36.0",
    "@mastra/express": "^1.3.23",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "mastra": "^1.10.0",
    "next": "^16.2.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
